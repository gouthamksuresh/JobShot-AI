# JobShot AI v2 — Environment Variables
# Copy to .env and fill in values

# ── AI ─────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email ──────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=me.goutham.tech@gmail.com
# App Password (NOT your real password)
# How to get: Google Account → Security → 2-Step → App Passwords → Mail
GMAIL_APP_PASS=your_16_char_app_password_here

# ── Google Sheets (optional) ───────────────────────────
# Only needed for "Export to Sheets" feature
# 1. console.cloud.google.com → New Project → Enable Sheets API
# 2. Create Service Account → Download JSON key
# 3. Share your Google Sheet with the service account email
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account-key.json
